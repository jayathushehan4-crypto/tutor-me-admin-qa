# Sentry browser DSN from your Sentry project settings.
# Put the real value in your deployment environment or local .env when testing.
NEXT_PUBLIC_SENTRY_DSN=

# Use production or staging in deployed environments. Local development stays off
# unless NEXT_PUBLIC_SENTRY_ENABLED is set to true.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENABLED=false

# Optional: server-only DSN and source-map upload credentials for CI/deploy builds.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ENABLED=false
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
